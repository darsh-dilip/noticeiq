// Firebase Storage is NOT used in this application.
// We run on Firebase free (Spark) plan.
// Notice files are processed locally and never stored — only
// structured JSON analysis is saved in Firestore.

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
